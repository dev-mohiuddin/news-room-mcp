# ============================================
# Newsroom MCP — Backend Environment
# ============================================
# Copy to .env and fill in values. NEVER commit .env.

# --- App ---
NODE_ENV=development
PORT=8000
API_BASE_URL=http://localhost:8000
CLIENT_APP_ORIGIN=http://localhost:5173
SERVE_CLIENT_DIST=false
LOG_LEVEL=info

# --- Database ---
MONGO_URI=mongodb://127.0.0.1:27017/newsroom-mcp

# --- JWT ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-to-another-strong-random-secret
JWT_REFRESH_EXPIRES_IN=30d
ACCESS_TOKEN_COOKIE_MAX_AGE_DAYS=7
REFRESH_TOKEN_COOKIE_MAX_AGE_DAYS=30

# --- OTP ---
OTP_EXPIRES_MINUTES=10

# --- Seed credentials (used by initSuperAdmin) ---
SUPER_ADMIN_EMAIL=admin@newsroommcp.com
SUPER_ADMIN_PASSWORD=Admin@12345

# ============================================
# Email (choose one)
# ============================================
# Resend (recommended)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# SMTP fallback
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

FROM_EMAIL=noreply@newsroommcp.com

# ============================================
# Demo seed accounts (initSuperAdmin)
# ============================================
DEMO_USER_EMAIL=user@newsroommcp.com
DEMO_USER_PASSWORD=User@12345

# ============================================
# Google OAuth (sign-in with Google)
# ============================================
# Get from console.cloud.google.com → OAuth 2.0 Client IDs
# Same value must also be set in frontend/.env as VITE_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=

# ============================================
# Cloudinary (file/image uploads)
# ============================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ============================================
# AI / External Services (Newsroom MCP specific)
# ============================================
# Anthropic — primary writing model
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5-20251001

# OpenAI — optional fallback
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# Search providers
BRAVE_SEARCH_API_KEY=
EXA_API_KEY=

# Web scraping
FIRECRAWL_API_KEY=
JINA_API_KEY=

# SEO data
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Stripe (billing)
# Required for checkout / portal / webhook. Leave blank to disable
# Stripe paths — backend will return a structured 503 with code
# `STRIPE_NOT_CONFIGURED` so the frontend can show a friendly notice.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Local webhook test (in another terminal):
#   stripe listen --forward-to http://localhost:8000/api/v1/billing/stripe/webhook
# The CLI prints a `whsec_…` secret — paste it into STRIPE_WEBHOOK_SECRET.

# Encryption (for storing CMS credentials at rest)
# 32 bytes hex (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=

# ============================================
# Article Generation Pipeline
# ============================================

# Redis (BullMQ queue + cache)
REDIS_URL=redis://127.0.0.1:6379

# Worker concurrency (default 5)
ARTICLE_WORKER_CONCURRENCY=5

# Originality provider — one of: originality_ai | copyleaks
ORIGINALITY_PROVIDER=originality_ai
ORIGINALITY_THRESHOLD=0.15

# Originality.ai
ORIGINALITY_AI_API_KEY=

# Copyleaks (alternate)
COPYLEAKS_EMAIL=
COPYLEAKS_API_KEY=

# Unsplash (featured image search)
UNSPLASH_ACCESS_KEY=

# ============================================
# Notifications
# ============================================
# Auto-purge in-app notifications older than N days. Set to 0 to disable.
NOTIFICATION_RETENTION_DAYS=90

# ============================================
# Analytics — view tracking
# ============================================
# Hashing salt for visitor de-dupe (set to a long random string in production
# so dedupe hashes can't be reverse-engineered to user IPs).
VIEW_TRACKING_SALT=change-this-to-a-long-random-string-for-prod
# Auto-purge raw view events older than N days. Set to 0 to disable TTL.
ARTICLE_VIEW_RETENTION_DAYS=180

# ============================================================
# Multi-step Article Wizard
# ============================================================
# Feature flag: when "true", mounts the wizard endpoints under
# /api/v1/articles/wizard/* and /api/v1/articles/:id/stages/*.
# Leave unset/false to keep only the legacy one-shot generate flow.
ENABLE_WIZARD_BACKEND=false

# Wizard-stage worker concurrency (defaults to 5)
WIZARD_STAGE_WORKER_CONCURRENCY=5

# Quota reconciliation cron — interval in minutes (default 60).
# The sweeper retries any article whose non-recoverable failure left
# quotaRefunded:false (e.g. transient Redis/Mongo error during refund).
QUOTA_RECONCILIATION_INTERVAL_MIN=60

# ============================================
# Human-Like Article Pipeline feature flags
# ============================================
# All flags are interpreted as `true` only when set to the case-insensitive
# string "true". Any other value (unset, empty, "false", "0", etc.) is
# interpreted as false. Defaults preserve pre-feature behavior.

# Master flag for all human-like-article-pipeline behavior.
HUMAN_LIKE_PIPELINE_ENABLED=false

# Gates Source Enrichment Service on PATCH /source-selections.
HLP_SOURCE_ENRICH_ENABLED=false

# Gates Outline Enricher on outline regenerate.
HLP_OUTLINE_ENRICH_ENABLED=false

# Gates Draft Formatter normalization on draft persistence.
HLP_DRAFT_FORMAT_ENABLED=false

# Gates SEO Validator hardening (URL canonicalization, length rebalancing,
# per-error hints, etc.).
HLP_SEO_HARDEN_ENABLED=false

# Tone-adaptive temperature + topP (Professional=0.45, Casual=0.75,
# Journalistic=0.65, Academic=0.35). Flag OFF → legacy temperature: 0.5.
HLP_TONE_ADAPTIVE_TEMPERATURE=false

# Post-draft burstiness (sentence-length variance) validation.
HLP_BURSTINESS_VALIDATION_ENABLED=false

# Post-draft paragraph-length variation validation.
HLP_PARAGRAPH_VARIATION_ENABLED=false

# Anti-cliché phrase scanner on generated drafts.
HLP_ANTICLICHE_SCANNER_ENABLED=false

# Paragraph opening-pattern diversity validation.
HLP_OPENING_DIVERSITY_ENABLED=false

# Originality/AI-detection gate in wizard pipeline (after draft, before SEO).
HLP_ORIGINALITY_GATE_ENABLED=false

# Two-pass drafting: Haiku rough → Sonnet polish.
HLP_TWO_PASS_DRAFTING_ENABLED=false

# Model rotation across Sonnet / Opus / Haiku per article.
HLP_MODEL_ROTATION_ENABLED=false

# Deep source read: top 3 sources get 5000-char excerpt vs 2500.
HLP_DEEP_SOURCE_READ_ENABLED=false


HUMAN_LIKE_PIPELINE_ENABLED=true
HLP_SOURCE_ENRICH_ENABLED=true
HLP_OUTLINE_ENRICH_ENABLED=true
HLP_DRAFT_FORMAT_ENABLED=true
HLP_SEO_HARDEN_ENABLED=true

ORIGINALITY_PROVIDER=copyleaks
COPYLEAKS_EMAIL=mern.dev.mohiuddin@gmail.com
COPYLEAKS_API_KEY=6f0e3b0c-2d27-46d1-8603-939f83sjkslds
HLP_ORIGINALITY_GATE_ENABLED=true   


HLP_TONE_ADAPTIVE_TEMPERATURE=true
HLP_BURSTINESS_VALIDATION_ENABLED=true
HLP_PARAGRAPH_VARIATION_ENABLED=true
HLP_ANTICLICHE_SCANNER_ENABLED=true

HLP_OPENING_DIVERSITY_ENABLED=true
HLP_DEEP_SOURCE_READ_ENABLED=true
HLP_TWO_PASS_DRAFTING_ENABLED=true