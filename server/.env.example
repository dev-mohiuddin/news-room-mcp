# ============================================
# ShareBit Server - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
#
# For Docker/Railway deployment, see .env.docker

# --- App Settings ---
NODE_ENV=development
PORT=8000
CLIENT_APP_ORIGIN=http://localhost:5173
SERVE_CLIENT_DIST=false

# --- Database ---
MONGO_URI=mongodb://127.0.0.1:27017/sharebit

# --- JWT Secrets (Use strong random strings in production) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-strong-random-secret-key-for-access-tokens
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-to-a-different-strong-random-secret-key-for-refresh-tokens
JWT_REFRESH_EXPIRES_IN=30d
ACCESS_TOKEN_COOKIE_MAX_AGE_DAYS=7
REFRESH_TOKEN_COOKIE_MAX_AGE_DAYS=30

# --- OTP Settings ---
OTP_EXPIRES_MINUTES=10

# --- Seed Accounts (Demo credentials) ---
SUPER_ADMIN_EMAIL=admin@sharebit.com
SUPER_ADMIN_PASSWORD=Admin@12345
COMPANY_SYSTEM_EMAIL=company@sharebit.com

# ============================================
# EMAIL SERVICE (Choose ONE option)
# ============================================
# Option 1: Resend (Recommended for production)
# Sign up at https://resend.com and get your API key
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Option 2: SMTP (Gmail, SendGrid, Mailgun, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# From email address (used in all outgoing emails)
FROM_EMAIL=noreply@sharebit.com

# ============================================
# CLOUDINARY (File/Image Storage)
# ============================================
# Sign up at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
